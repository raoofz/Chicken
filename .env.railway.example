# ═══════════════════════════════════════════════════════════════
# متغيرات البيئة المطلوبة على Railway
# Environment Variables Required on Railway
# ═══════════════════════════════════════════════════════════════

# [تلقائي] يُوفّره Railway تلقائياً - لا تضعه يدوياً
# PORT=  (auto-provided by Railway)

# [تلقائي] يُوفّره Railway عند إنشاء قاعدة بيانات PostgreSQL
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# [مطلوب] مفتاح عشوائي آمن لتشفير الجلسات - أنشئ واحداً بالأمر أدناه:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX_STRING

# [تلقائي] يُضبط في railway.toml
NODE_ENV=production
